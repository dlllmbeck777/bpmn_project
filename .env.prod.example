# Production environment example
# Copy to .env.prod or generate one with:
#   bash scripts/generate-env.sh .env.prod

DOMAIN=admin.yourdomain.com

CONFIG_DB_NAME=config
CONFIG_DB_USER=config
CONFIG_DB_PASSWORD=change-me-config-db-password

FLOWABLE_DB_PASSWORD=change-me-flowable-db-password

ENCRYPT_KEY=change-me-long-random-secret

GATEWAY_API_KEY=change-me-gateway-key
ADMIN_API_KEY=change-me-admin-key
SENIOR_ANALYST_API_KEY=change-me-senior-key
ANALYST_API_KEY=change-me-analyst-key
INTERNAL_API_KEY=change-me-internal-key

FLOWABLE_PASSWORD=change-me-flowable-password
FLOWABLE_PASSWORD_FALLBACKS=test
FLOWABLE_AUTO_DEPLOY_BPMN=false
FLOWABLE_REST_JAVA_TOOL_OPTIONS=-Xms384m -Xmx1024m -XX:MaxMetaspaceSize=384m -XX:+ExitOnOutOfMemoryError
FLOWABLE_UI_JAVA_TOOL_OPTIONS=-Xms512m -Xmx1024m -XX:MaxMetaspaceSize=384m -XX:+ExitOnOutOfMemoryError
CREDIT_BACKEND_DEFAULT_URL=http://18.119.38.114
CREDIT_BACKEND_TIMEOUT_MS=15000
MOCK_PUBLIC_BASE_URL=https://admin.yourdomain.com/mock-bureaus
MOCK_UPSTREAM_LABEL=http://18.119.38.114
GRAFANA_PASSWORD=change-me-grafana-password

ADMIN_LOGIN_USERNAME=admin
ADMIN_LOGIN_PASSWORD=change-me-admin-login-password
SENIOR_ANALYST_LOGIN_USERNAME=senior
SENIOR_ANALYST_LOGIN_PASSWORD=change-me-senior-login-password
ANALYST_LOGIN_USERNAME=analyst
ANALYST_LOGIN_PASSWORD=change-me-analyst-login-password

SESSION_TTL_HOURS=8
DB_POOL_MIN=4
DB_POOL_MAX=20
LOG_LEVEL=INFO
RATE_LIMIT_PER_MIN=60

CORS_ORIGINS=https://admin.yourdomain.com

SNP_EXTERNAL_URL=
