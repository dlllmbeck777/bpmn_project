<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://example.com/credit-service-chain">

  <error id="serviceError" errorCode="HTTP_TASK_ERROR"/>

  <process id="creditServiceChainOrchestration" name="Credit Service Chain Orchestration" isExecutable="true">

    <startEvent id="startEvent" name="Request received"/>
    <sequenceFlow id="flow_start_to_init" sourceRef="startEvent" targetRef="task_init"/>

    <scriptTask id="task_init" name="Initialize context" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        execution.setVariable('route_mode', execution.getVariable('route_mode') ?: 'FLOWABLE')
        execution.setVariable('request_id', execution.getVariable('request_id') ?: '')
        execution.setVariable('customer_id', execution.getVariable('customer_id') ?: '')
        execution.setVariable('iin', execution.getVariable('iin') ?: '')
        execution.setVariable('external_applicant_id', execution.getVariable('external_applicant_id') ?: '')
        execution.setVariable('product_type', execution.getVariable('product_type') ?: '')
        execution.setVariable('applicant_json', execution.getVariable('applicant_json') ?: '{}')
        execution.setVariable('decision_service_url', execution.getVariable('decision_service_url') ?: '')
        execution.setVariable('decision_request_body', execution.getVariable('decision_request_body') ?: '{}')
      ]]></script>
    </scriptTask>

    <exclusiveGateway id="gateway_iso" name="Skip iSoftPull?" default="flow_iso_gate_to_call"/>
    <sequenceFlow id="flow_init_to_iso" sourceRef="task_init" targetRef="gateway_iso"/>
    <sequenceFlow id="flow_iso_gate_to_skip" sourceRef="gateway_iso" targetRef="task_iso_skip">
      <conditionExpression xsi:type="tFormalExpression">${skip_isoftpull}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_iso_gate_to_call" sourceRef="gateway_iso" targetRef="task_isoftpull"/>

    <scriptTask id="task_iso_skip" name="Skip iSoftPull" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def reason = ((execution.getVariable('skip_reason_isoftpull') ?: 'pipeline step skipped by policy') as String).replace('"', '\\"')
        execution.setVariable('isoRawBody', '{"status":"SKIPPED","reason":"' + reason + '"}')
        execution.setVariable('iso_status', 'SKIPPED')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_iso_skip_to_prep_cs" sourceRef="task_iso_skip" targetRef="task_prepare_creditsafe_body"/>

    <serviceTask id="task_isoftpull" name="Call iSoftPull" flowable:exclusive="false" flowable:type="http">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R2/PT5S</flowable:failedJobRetryTimeCycle>
        <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="requestUrl"><flowable:expression>${isoftpull_url}</flowable:expression></flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:expression>Content-Type: application/json
X-Request-Id: ${request_id}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestBody">
          <flowable:expression>{"request_id":"${request_id}","customer_id":"${customer_id}","iin":"${iin}","external_applicant_id":"${external_applicant_id}","product_type":"${product_type}","applicant":${applicant_json}}</flowable:expression>
        </flowable:field>
        <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
        <flowable:field name="resultVariablePrefix"><flowable:string>isoRaw</flowable:string></flowable:field>
        <flowable:field name="requestTimeout"><flowable:string>10000</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="err_iso" attachedToRef="task_isoftpull" cancelActivity="true">
      <errorEventDefinition errorRef="serviceError"/>
    </boundaryEvent>
    <scriptTask id="task_iso_degrade" name="iSoftPull degrade" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        execution.setVariable('isoRawBody', '{}')
        execution.setVariable('iso_status', 'UNAVAILABLE')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_err_iso" sourceRef="err_iso" targetRef="task_iso_degrade"/>
    <sequenceFlow id="flow_iso_deg_to_prep_cs" sourceRef="task_iso_degrade" targetRef="task_prepare_creditsafe_body"/>

    <scriptTask id="task_parse_iso" name="Parse iSoftPull" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def raw = ((execution.getVariable('isoRawResponseBody') ?: execution.getVariable('isoRawBody') ?: '{}')) as String
        execution.setVariable('isoRawBody', raw)
        def mv = raw =~ /"status"\s*:\s*"([^"]+)"/
        execution.setVariable('iso_status', mv.find() ? mv.group(1) : 'OK')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_iso_to_parse" sourceRef="task_isoftpull" targetRef="task_parse_iso"/>
    <sequenceFlow id="flow_parse_iso_to_prep_cs" sourceRef="task_parse_iso" targetRef="task_prepare_creditsafe_body"/>

    <scriptTask id="task_prepare_creditsafe_body" name="Prepare Creditsafe body" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def isoBody = (execution.getVariable('isoRawBody') ?: '{}') as String
        def body = '{"request_id":"' + execution.getVariable('request_id') + '",' +
                   '"customer_id":"' + execution.getVariable('customer_id') + '",' +
                   '"iin":"' + execution.getVariable('iin') + '",' +
                   '"external_applicant_id":"' + execution.getVariable('external_applicant_id') + '",' +
                   '"applicant":' + (execution.getVariable('applicant_json') ?: '{}') + ',' +
                   '"isoftpull":' + isoBody + '}'
        execution.setVariable('creditsafe_request_body', body)
      ]]></script>
    </scriptTask>

    <exclusiveGateway id="gateway_cs" name="Skip Creditsafe?" default="flow_cs_gate_to_call"/>
    <sequenceFlow id="flow_prep_cs_to_call" sourceRef="task_prepare_creditsafe_body" targetRef="gateway_cs"/>
    <sequenceFlow id="flow_cs_gate_to_skip" sourceRef="gateway_cs" targetRef="task_cs_skip">
      <conditionExpression xsi:type="tFormalExpression">${skip_creditsafe}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_cs_gate_to_call" sourceRef="gateway_cs" targetRef="task_creditsafe"/>

    <scriptTask id="task_cs_skip" name="Skip Creditsafe" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def reason = ((execution.getVariable('skip_reason_creditsafe') ?: 'pipeline step skipped by policy') as String).replace('"', '\\"')
        execution.setVariable('csRawBody', '{"status":"SKIPPED","reason":"' + reason + '"}')
        execution.setVariable('creditsafe_status', 'SKIPPED')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_cs_skip_to_prep_plaid" sourceRef="task_cs_skip" targetRef="task_prepare_plaid_body"/>

    <serviceTask id="task_creditsafe" name="Call Creditsafe" flowable:exclusive="false" flowable:type="http">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R2/PT5S</flowable:failedJobRetryTimeCycle>
        <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="requestUrl"><flowable:expression>${creditsafe_url}</flowable:expression></flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:expression>Content-Type: application/json
X-Request-Id: ${request_id}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestBody"><flowable:expression>${creditsafe_request_body}</flowable:expression></flowable:field>
        <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
        <flowable:field name="resultVariablePrefix"><flowable:string>csRaw</flowable:string></flowable:field>
        <flowable:field name="requestTimeout"><flowable:string>10000</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="err_cs" attachedToRef="task_creditsafe" cancelActivity="true">
      <errorEventDefinition errorRef="serviceError"/>
    </boundaryEvent>
    <scriptTask id="task_cs_degrade" name="Creditsafe degrade" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        execution.setVariable('csRawBody', '{}')
        execution.setVariable('creditsafe_status', 'UNAVAILABLE')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_err_cs" sourceRef="err_cs" targetRef="task_cs_degrade"/>
    <sequenceFlow id="flow_cs_deg_to_prep_plaid" sourceRef="task_cs_degrade" targetRef="task_prepare_plaid_body"/>

    <scriptTask id="task_parse_cs" name="Parse Creditsafe" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def raw = ((execution.getVariable('csRawResponseBody') ?: execution.getVariable('csRawBody') ?: '{}')) as String
        execution.setVariable('csRawBody', raw)
        def mv = raw =~ /"status"\s*:\s*"([^"]+)"/
        execution.setVariable('creditsafe_status', mv.find() ? mv.group(1) : 'OK')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_cs_to_parse" sourceRef="task_creditsafe" targetRef="task_parse_cs"/>
    <sequenceFlow id="flow_parse_cs_to_prep_plaid" sourceRef="task_parse_cs" targetRef="task_prepare_plaid_body"/>

    <scriptTask id="task_prepare_plaid_body" name="Prepare Plaid body" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def csBody = (execution.getVariable('csRawBody') ?: '{}') as String
        def body = '{"request_id":"' + execution.getVariable('request_id') + '",' +
                   '"customer_id":"' + execution.getVariable('customer_id') + '",' +
                   '"iin":"' + execution.getVariable('iin') + '",' +
                   '"external_applicant_id":"' + execution.getVariable('external_applicant_id') + '",' +
                   '"applicant":' + (execution.getVariable('applicant_json') ?: '{}') + ',' +
                   '"creditsafe":' + csBody + '}'
        execution.setVariable('plaid_request_body', body)
      ]]></script>
    </scriptTask>

    <exclusiveGateway id="gateway_plaid" name="Skip Plaid?" default="flow_plaid_gate_to_call"/>
    <sequenceFlow id="flow_prep_plaid_to_call" sourceRef="task_prepare_plaid_body" targetRef="gateway_plaid"/>
    <sequenceFlow id="flow_plaid_gate_to_skip" sourceRef="gateway_plaid" targetRef="task_plaid_skip">
      <conditionExpression xsi:type="tFormalExpression">${skip_plaid}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_plaid_gate_to_call" sourceRef="gateway_plaid" targetRef="task_plaid"/>

    <scriptTask id="task_plaid_skip" name="Skip Plaid" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def reason = ((execution.getVariable('skip_reason_plaid') ?: 'pipeline step skipped by policy') as String).replace('"', '\\"')
        execution.setVariable('plaidRawBody', '{"status":"SKIPPED","reason":"' + reason + '"}')
        execution.setVariable('plaid_status', 'SKIPPED')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_plaid_skip_to_prep_decision" sourceRef="task_plaid_skip" targetRef="task_prepare_decision_body"/>

    <serviceTask id="task_plaid" name="Call Plaid" flowable:exclusive="false" flowable:type="http">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R2/PT5S</flowable:failedJobRetryTimeCycle>
        <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="requestUrl"><flowable:expression>${plaid_url}</flowable:expression></flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:expression>Content-Type: application/json
X-Request-Id: ${request_id}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestBody"><flowable:expression>${plaid_request_body}</flowable:expression></flowable:field>
        <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
        <flowable:field name="resultVariablePrefix"><flowable:string>plaidRaw</flowable:string></flowable:field>
        <flowable:field name="requestTimeout"><flowable:string>10000</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="err_plaid" attachedToRef="task_plaid" cancelActivity="true">
      <errorEventDefinition errorRef="serviceError"/>
    </boundaryEvent>
    <scriptTask id="task_plaid_degrade" name="Plaid degrade" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        execution.setVariable('plaidRawBody', '{}')
        execution.setVariable('plaid_status', 'UNAVAILABLE')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_err_plaid" sourceRef="err_plaid" targetRef="task_plaid_degrade"/>
    <sequenceFlow id="flow_plaid_deg_to_prep_decision" sourceRef="task_plaid_degrade" targetRef="task_prepare_decision_body"/>

    <scriptTask id="task_parse_plaid" name="Parse Plaid" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def raw = ((execution.getVariable('plaidRawResponseBody') ?: execution.getVariable('plaidRawBody') ?: '{}')) as String
        execution.setVariable('plaidRawBody', raw)
        def mv = raw =~ /"status"\s*:\s*"([^"]+)"/
        execution.setVariable('plaid_status', mv.find() ? mv.group(1) : 'OK')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_plaid_to_parse" sourceRef="task_plaid" targetRef="task_parse_plaid"/>
    <sequenceFlow id="flow_parse_plaid_to_prep_decision" sourceRef="task_parse_plaid" targetRef="task_prepare_decision_body"/>

    <scriptTask id="task_prepare_decision_body" name="Prepare decision body" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        import com.fasterxml.jackson.databind.ObjectMapper

        def mapper = new ObjectMapper()

        def parseStep = { rawKey, statusKey, reasonKey, serviceId ->
          def rawValue = (execution.getVariable(rawKey) ?: '{}') as String
          def parsed
          try {
            parsed = mapper.readValue(rawValue, java.util.LinkedHashMap)
          } catch (Exception ignored) {
            parsed = [:]
          }
          if (!(parsed instanceof Map)) {
            parsed = [:]
          }
          parsed['service'] = serviceId
          parsed['status'] = parsed['status'] ?: (execution.getVariable(statusKey) ?: 'UNKNOWN')
          def reason = execution.getVariable(reasonKey)
          if (reason && !parsed['reason']) {
            parsed['reason'] = reason
          }
          return parsed
        }

        def payload = [
          request_id: execution.getVariable('request_id'),
          route_mode: execution.getVariable('route_mode'),
          external_applicant_id: execution.getVariable('external_applicant_id'),
          steps: [
            isoftpull: parseStep('isoRawBody', 'iso_status', 'skip_reason_isoftpull', 'isoftpull'),
            creditsafe: parseStep('csRawBody', 'creditsafe_status', 'skip_reason_creditsafe', 'creditsafe'),
            plaid: parseStep('plaidRawBody', 'plaid_status', 'skip_reason_plaid', 'plaid'),
          ],
        ]
        execution.setVariable('decision_request_body', mapper.writeValueAsString(payload))
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_prep_decision_to_call" sourceRef="task_prepare_decision_body" targetRef="task_ai_assess"/>

    <!-- AI Risk Assessment — after prepare decision body, before decision service -->
    <serviceTask id="task_ai_assess" name="AI Risk Assessment"
                 flowable:type="http" flowable:exclusive="false">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R1/PT5S</flowable:failedJobRetryTimeCycle>
        <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="requestUrl"><flowable:expression>${ai_advisor_url}</flowable:expression></flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:expression>Content-Type: application/json
X-Request-Id: ${request_id}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestBody">
          <flowable:expression>{"request_id":"${request_id}","context":{"route_mode":"FLOWABLE","product_type":"${product_type}"}}</flowable:expression>
        </flowable:field>
        <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
        <flowable:field name="resultVariablePrefix"><flowable:string>aiRaw</flowable:string></flowable:field>
        <flowable:field name="requestTimeout"><flowable:string>15000</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="err_ai" attachedToRef="task_ai_assess" cancelActivity="true">
      <errorEventDefinition errorRef="serviceError"/>
    </boundaryEvent>
    <scriptTask id="task_ai_degrade" name="AI degrade" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        def statusCode = execution.getVariable('aiRawStatusCode')
        def errorBody = execution.getVariable('aiRawBody') ?: ''
        println "[ai-degrade] statusCode=${statusCode} body=${errorBody?.toString()?.take(200)}"
        execution.setVariable('aiRawBody', '{"risk_score":50,"risk_level":"MEDIUM","recommendation":"REVIEW","narrative":"AI advisor unavailable (status: ' + statusCode + ')","fallback":true}')
        execution.setVariable('ai_status', 'UNAVAILABLE')
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_err_ai" sourceRef="err_ai" targetRef="task_ai_degrade"/>
    <sequenceFlow id="flow_ai_deg_to_decision" sourceRef="task_ai_degrade" targetRef="task_decision_service"/>
    <exclusiveGateway id="gw_ai_status" name="AI response ok?"/>
    <sequenceFlow id="flow_ai_to_gw" sourceRef="task_ai_assess" targetRef="gw_ai_status"/>
    <sequenceFlow id="flow_ai_ok" sourceRef="gw_ai_status" targetRef="task_decision_service">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${aiRawStatusCode != null && aiRawStatusCode == 200}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_ai_err_status" sourceRef="gw_ai_status" targetRef="task_ai_degrade">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${aiRawStatusCode == null || aiRawStatusCode != 200}]]></conditionExpression>
    </sequenceFlow>

    <serviceTask id="task_decision_service" name="Call Decision Service" flowable:exclusive="false" flowable:type="http">
      <extensionElements>
        <flowable:failedJobRetryTimeCycle>R2/PT5S</flowable:failedJobRetryTimeCycle>
        <flowable:field name="requestMethod"><flowable:string>POST</flowable:string></flowable:field>
        <flowable:field name="requestUrl"><flowable:expression>${decision_service_url}</flowable:expression></flowable:field>
        <flowable:field name="requestHeaders">
          <flowable:expression>Content-Type: application/json
X-Request-Id: ${request_id}</flowable:expression>
        </flowable:field>
        <flowable:field name="requestBody"><flowable:expression>${decision_request_body}</flowable:expression></flowable:field>
        <flowable:field name="saveResponseParameters"><flowable:string>true</flowable:string></flowable:field>
        <flowable:field name="resultVariablePrefix"><flowable:string>decisionRaw</flowable:string></flowable:field>
        <flowable:field name="requestTimeout"><flowable:string>10000</flowable:string></flowable:field>
      </extensionElements>
    </serviceTask>
    <boundaryEvent id="err_decision" attachedToRef="task_decision_service" cancelActivity="true">
      <errorEventDefinition errorRef="serviceError"/>
    </boundaryEvent>
    <scriptTask id="task_decision_degrade" name="Decision degrade" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        import com.fasterxml.jackson.databind.ObjectMapper

        def mapper = new ObjectMapper()
        def decisionReason = 'Decision service unavailable'
        def parseStep = { rawKey, statusKey, reasonKey, serviceId ->
          def rawValue = (execution.getVariable(rawKey) ?: '{}') as String
          def parsed
          try {
            parsed = mapper.readValue(rawValue, java.util.LinkedHashMap)
          } catch (Exception ignored) {
            parsed = [:]
          }
          if (!(parsed instanceof Map)) {
            parsed = [:]
          }
          parsed['service'] = serviceId
          parsed['status'] = parsed['status'] ?: (execution.getVariable(statusKey) ?: 'UNKNOWN')
          def reason = execution.getVariable(reasonKey)
          if (reason && !parsed['reason']) {
            parsed['reason'] = reason
          }
          return parsed
        }
        def steps = [
          isoftpull: parseStep('isoRawBody', 'iso_status', 'skip_reason_isoftpull', 'isoftpull'),
          creditsafe: parseStep('csRawBody', 'creditsafe_status', 'skip_reason_creditsafe', 'creditsafe'),
          plaid: parseStep('plaidRawBody', 'plaid_status', 'skip_reason_plaid', 'plaid'),
        ]
        def payload = [
          status: 'ENGINE_ERROR',
          request_id: execution.getVariable('request_id'),
          decision: null,
          decision_reason: decisionReason,
          decision_source: 'decision-service',
          request_context: [
            request_id: execution.getVariable('request_id'),
            route_mode: execution.getVariable('route_mode'),
            external_applicant_id: execution.getVariable('external_applicant_id'),
          ],
          steps: steps,
          external_reports: steps,
          step_statuses: [
            isoftpull: steps.isoftpull.status,
            creditsafe: steps.creditsafe.status,
            plaid: steps.plaid.status,
          ],
          summary: [
            request_id: execution.getVariable('request_id'),
            route_mode: execution.getVariable('route_mode'),
            decision: null,
            decision_source: 'decision-service',
            decision_reason: decisionReason,
            rules_evaluated: 0,
            matched_rule: null,
            iso_status: steps.isoftpull.status,
            creditsafe_status: steps.creditsafe.status,
            plaid_status: steps.plaid.status,
          ],
        ]
        execution.setVariable('decisionRawBody', mapper.writeValueAsString(payload))
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_err_decision" sourceRef="err_decision" targetRef="task_decision_degrade"/>
    <sequenceFlow id="flow_decision_deg_to_parse" sourceRef="task_decision_degrade" targetRef="task_parse_decision"/>

    <scriptTask id="task_parse_decision" name="Parse decision" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <script><![CDATA[
        import com.fasterxml.jackson.databind.ObjectMapper

        def mapper = new ObjectMapper()

        def raw = ((execution.getVariable('decisionRawResponseBody') ?: execution.getVariable('decisionRawBody') ?: '{}')) as String
        execution.setVariable('decisionRawBody', raw)
        def parsed
        try {
          parsed = mapper.readValue(raw, java.util.LinkedHashMap)
        } catch (Exception ignored) {
          parsed = [
            status: 'ENGINE_ERROR',
            request_id: execution.getVariable('request_id'),
            decision_reason: 'Decision payload is invalid',
            decision_source: 'decision-service',
          ]
        }
        if (!(parsed instanceof Map)) {
          parsed = [
            status: 'ENGINE_ERROR',
            request_id: execution.getVariable('request_id'),
            decision_reason: 'Decision payload is invalid',
            decision_source: 'decision-service',
          ]
        }
        execution.setVariable('decision_status', parsed['status'] ?: 'ENGINE_ERROR')
        execution.setVariable('orchestration_result', mapper.writeValueAsString(parsed))
      ]]></script>
    </scriptTask>
    <sequenceFlow id="flow_decision_to_parse" sourceRef="task_decision_service" targetRef="task_parse_decision"/>
    <sequenceFlow id="flow_parse_decision_to_end" sourceRef="task_parse_decision" targetRef="endEvent"/>

    <endEvent id="endEvent" name="Completed"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_creditServiceChainOrchestration">
    <bpmndi:BPMNPlane id="BPMNPlane_creditServiceChainOrchestration" bpmnElement="creditServiceChainOrchestration">
      <bpmndi:BPMNShape id="shape_start" bpmnElement="startEvent"><omgdc:Bounds x="100" y="180" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_init" bpmnElement="task_init"><omgdc:Bounds x="180" y="158" width="120" height="80"/></bpmndi:BPMNShape>
